# Database — Neon pooled connection string (used by the app at runtime)
DATABASE_URL=

# Database — Neon direct connection string (used only for drizzle-kit migrations)
DATABASE_URL_DIRECT=

# Recipient public key — safe to expose publicly; used by the browser to encrypt messages
# Generate with: npm run generate-keypair
NEXT_PUBLIC_RECIPIENT_PUBLIC_KEY=

# Inbox password hash — bcrypt hash (cost=12) of your chosen inbox password
# Generate with: node -e "const b=require('bcryptjs'); b.hash('yourpassword',12).then(console.log)"
# NEVER use NEXT_PUBLIC_ prefix here — this must stay server-side only
INBOX_PASSWORD_HASH=

# Valid codewords — comma-separated list of accepted codewords (client-side check)
# Update this list whenever you add or remove a codeword
# Example: NEXT_PUBLIC_VALID_CODEWORDS=wordone,wordtwo,wordthree
NEXT_PUBLIC_VALID_CODEWORDS=

# Upstash Redis — for rate limiting on the submission endpoint
# Create a free database at upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
